# SPDX-License-Identifier: Apache-2.0
# Solo E2E Test Environment - Copy to .env and customize

# Topology: single (default), paired-3, fan-out-3cn-2bn (see: task topologies)
TOPOLOGY=single

# Cluster
CLUSTER_NAME=solo-cluster
NAMESPACE=solo-network
DEPLOYMENT=deployment-solo

# Versions: 'latest', 'rc' or specific tag (e.g., 'v0.73.0')
CN_VERSION=latest
# Versions: 'latest', 'rc' or specific tag (e.g., 'v0.152.0')
MN_VERSION=latest
# Versions: 'latest', 'rc', 'main', or specific tag (e.g., 'v0.31.0')
BN_VERSION=latest
# Compatibility constraint: CN >=0.73.x requires BN >=0.31.x and MN >=0.152.x
# Update all three together once MN 0.152.x-rc is available.
RELAY_VERSION=latest
SOLO_VERSION=latest
TCK_VERSION=latest
# JS-SDK (hiero-sdk-js) version for the TCK server.
# Defaults to a pinned version (see Taskfile.yml) rather than 'latest', because
# upstream releases may reference proto packages that were never published to npm.
# Override here only when you need a specific version. Example: SDK_VERSION=v2.82.0
# Upstream issue: https://github.com/hiero-ledger/hiero-block-node/issues/2480
# SDK_VERSION=v2.81.0

# TSS/WRAPS on consensus nodes enabled (default: true)
TSS_ENABLED=true

# NLG Load Generation (for task load:up)
# Test type: CryptoTransferLoadTest, HCSLoadTest, TokenTransferLoadTest, NftTransferLoadTest
NLG_TEST_TYPE=CryptoTransferLoadTest
#
# Args passed directly to load test:
#   -c <clients>    Concurrent clients/threads (default: 5)
#   -a <accounts>   Number of test accounts to create (default: 10)
#   -t/-tt <time>   Duration in seconds, or with suffix: 60, 5m, 1h (default: 300)
#
# Test-specific args:
#   -n <topics>     HCSLoadTest: number of topics
#   -T <tokens>     NftTransferLoadTest/TokenTransferLoadTest: number of tokens
#   -n <nfts>       NftTransferLoadTest: NFTs per token
#   -A <assoc>      TokenTransferLoadTest: associations per account
NLG_ARGS=-c 5 -a 10 -tt 300
# Optional: rate limit (uses RateLimitedQueue instead of AdaptiveQueue)
# NLG_MAX_TPS=100

# Solo environment variables (passed through to Solo CLI)
MIRROR_NODE_PINGER_TPS=5  # Mirror Node pinger TPS (0 to disable)

# Local Metrics (Prometheus+Grafana stack on last block-node)
ENABLE_LOCAL_METRICS=false

# Test Definition (for task test:run): none, smoke-test.yaml, basic-load.yaml, node-restart-resilience.yaml, tss-signature-transition.yaml
TEST_FILE=none
